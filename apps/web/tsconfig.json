{
    "extends": "@workspace/typescript-config/nextjs.json",
    "compilerOptions": {
        // Next.js emits nothing (noEmit); disabling declarations avoids TS2742
        // "inferred type cannot be named" errors from libraries like Better Auth.
        "declaration": false,
        "declarationMap": false,
        "paths": {
            // `@/api/*` maps to lib/api so the fetcher layer keeps its stable
            // import path WITHOUT a root-level `api/` folder, which Vercel would
            // otherwise treat as zero-config Serverless Functions and fail to
            // resolve (no tsconfig paths in that builder). Keep this above `@/*`;
            // TS/Turbopack pick the longest-matching prefix.
            "@/api/*": ["./lib/api/*"],
            "@/*": ["./*"],
            "@workspace/ui/*": ["../../packages/ui/src/*"]
        },
        "plugins": [
            {
                "name": "next"
            }
        ]
    },
    "include": [
        "next-env.d.ts",
        "next.config.ts",
        "**/*.ts",
        "**/*.tsx",
        "**/*.mts",
        ".next/types/**/*.ts",
        ".next/dev/types/**/*.ts"
    ],
    "exclude": ["node_modules"]
}
