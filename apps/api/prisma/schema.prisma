// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "./generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum CommunityStatus {
  NOW_SELLING
  COMING_SOON
  SOLD_OUT
}

enum MediaType {
  IMAGE
  VIDEO
}

// ─── Geography ────────────────────────────────────────────────────────────────

model Region {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  state     String   @default("Florida")
  counties  County[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model County {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  // Bounding box for map viewport fitting
  boundsNorth Float
  boundsSouth Float
  boundsEast  Float
  boundsWest  Float
  regionId    String
  region      Region      @relation(fields: [regionId], references: [id])
  communities Community[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// ─── Community ────────────────────────────────────────────────────────────────

model Community {
  id           String             @id @default(cuid())
  slug         String             @unique
  name         String
  brand        String?
  location     String
  image        String
  status       CommunityStatus
  homesForSale Int                @default(0)
  // Bedroom range — single value sets min = max
  bedsMin      Int
  bedsMax      Int
  // Bath range — supports fractional (e.g. 2.5)
  bathsMin     Decimal            @db.Decimal(4, 1)
  bathsMax     Decimal            @db.Decimal(4, 1)
  // Garage range
  garageMin    Int
  garageMax    Int
  // Story range
  storiesMin   Int
  storiesMax   Int
  // Smallest available floor plan in sq ft
  sqftFrom     Int
  // Lowest starting price in whole dollars
  priceFrom    Int
  // Map coordinates
  lat          Float
  lng          Float
  about        String             @db.Text
  countyId     String
  county       County             @relation(fields: [countyId], references: [id])
  amenities    CommunityAmenity[]
  schools      School[]
  floorPlans   FloorPlanModel[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([countyId])
  @@index([status])
  @@index([priceFrom])
  @@index([lat, lng])
}

model Amenity {
  id          String             @id @default(cuid())
  name        String             @unique
  communities CommunityAmenity[]
}

model CommunityAmenity {
  communityId String
  amenityId   String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  amenity     Amenity   @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([communityId, amenityId])
}

model School {
  id          String     @id @default(cuid())
  name        String
  type        String
  grades      String
  // Display string preserved (e.g. "0.9 mi.") — not used for filtering
  distance    String
  communityId String
  community   Community  @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@index([communityId])
}

// ─── Floor Plans ──────────────────────────────────────────────────────────────

model FloorPlanModel {
  id            String          @id @default(cuid())
  // slug is unique per community, not globally (same plan name can appear in multiple communities)
  slug          String
  name          String
  brand         String?
  // Starting price in whole dollars
  startingPrice Int
  beds          Int
  // Supports fractional baths (e.g. 2.5)
  baths         Decimal         @db.Decimal(4, 1)
  garage        Int
  stories       Int
  sqft          Int
  image         String
  modelVideo    String?
  description   String?         @db.Text
  diagramImage  String?
  communityId   String
  community     Community       @relation(fields: [communityId], references: [id], onDelete: Cascade)
  gallery       FloorPlanModelMedia[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([communityId, slug])
  @@index([communityId])
  @@index([startingPrice])
}

model FloorPlanModelMedia {
  id          String    @id @default(cuid())
  type        MediaType
  src         String
  alt         String
  caption     String?
  sortOrder   Int       @default(0)
  floorPlanId String
  floorPlan   FloorPlanModel @relation(fields: [floorPlanId], references: [id], onDelete: Cascade)

  @@index([floorPlanId])
}

// ─── Auth & Agents (Better Auth) ──────────────────────────────────────────────
// Generated/aligned with `better-auth` core + organization + admin plugins.
// An "agent" (white-label reseller) is modelled as a Better Auth Organization —
// the org table is a Better Auth requirement; everything we surface calls it an
// "agent". The global catalog (Community/County/Region) is intentionally NOT
// scoped here — every agent's site shows the same platform-managed communities.

model User {
  id            String       @id @default(cuid())
  name          String
  email         String       @unique
  emailVerified Boolean      @default(true) // kept; no verification flow (admin-created = verified)
  image         String?
  role          String? // admin plugin: "admin" = platform super-admin (us); null/other = agent
  banned        Boolean? // admin plugin (present but unused — access control is Organization.serviceStatus)
  banReason     String?
  banExpires    DateTime?
  sessions      Session[]
  accounts      Account[]
  members       Member[]
  invitations   Invitation[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@map("user")
}

model Session {
  id                   String   @id @default(cuid())
  token                String   @unique
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeOrganizationId String? // org plugin: which agent the user is acting on
  impersonatedBy       String? // admin plugin
  ipAddress            String?
  userAgent            String?
  expiresAt            DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  password              String? // email/password hash
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// The Agent. Better Auth `organization` table + white-label additionalFields.
model Organization {
  id               String       @id @default(cuid())
  name             String
  slug             String       @unique
  logo             String? // R2 URL (built-in)
  metadata         String? // built-in, JSON string
  // --- additionalFields: white-label branding + access control ---
  serviceStatus    String       @default("active") // "active" | "suspended" (payment gate)
  customDomain     String?      @unique // agent domain, resolved by Host header
  domainStatus     String? // "pending" | "active" (Cloudflare)
  brandColor       String? // primary theme color (hex) — legacy single-color fallback
  theme            String?      @db.Text // JSON-serialized ThemeConfig (colors + radius + fonts, light/dark)
  siteName         String? // site name + <title>/SEO
  seoTitle         String? // home-page SEO <title> (falls back to siteName)
  titleSuffix      String? // brand suffix for sub-pages: "{name} | {titleSuffix}"
  metaDescription  String?      @db.Text // home meta description + og/twitter description
  contactPhone     String?
  footerText       String?
  ghlScheduleEmbed String?      @db.Text // per-agent /schedule embed
  // ── GHL sub-account fields (stored at creation; sent to GHL API once integrated) ──
  ownerFirstName                String?
  ownerLastName                 String?
  businessEmail                 String?  // GHL prospectInfo.email (may differ from login email)
  website                       String?
  address                       String?
  city                          String?
  state                         String?
  postalCode                    String?
  country                       String?  @default("US")
  timezone                      String?
  businessType                  String?
  ghlLocationId                 String?  @unique // set once the GHL sub-account is created
  // GHL location settings (persisted so the future API call can send them verbatim)
  ghlAllowDuplicateContact      Boolean  @default(false)
  ghlAllowDuplicateOpportunity  Boolean  @default(false)
  ghlAllowFacebookNameMerge     Boolean  @default(false)
  ghlDisableContactTimezone     Boolean  @default(false)
  members          Member[]
  invitations      Invitation[]
  createdAt        DateTime     @default(now())

  @@map("organization")
}

model Member {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String // "owner" | "admin" | "member" (org-scoped)
  createdAt      DateTime     @default(now())

  @@unique([organizationId, userId])
  @@map("member")
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String // "pending" | "accepted" | "canceled"
  expiresAt      DateTime
  inviterId      String
  inviter        User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@map("invitation")
}
