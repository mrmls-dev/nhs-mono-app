# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing — only the generated coverage output at the repo/package roots.
# A bare `coverage` also matched the Next.js route at
# app/dashboard/agents/[id]/coverage/, leaving its page untracked (404 in prod).
/coverage/
apps/*/coverage/
packages/*/coverage/

# next.js
.next/
out/

# production
build
dist

# turbo
.turbo

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

old
